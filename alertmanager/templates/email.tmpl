{{ define "email.subject" }}
[{{ .Status | toUpper }}] {{ .CommonLabels.alertname }}
{{ end }}

{{ define "email.html" }}
{{ $statusColor := "#d9534f" }}
{{ if eq .Status "resolved" }}{{ $statusColor = "#5cb85c" }}{{ end }}

<div style="font-family: 'Microsoft YaHei', Arial, sans-serif; max-width: 720px;">

  <h2 style="color: {{ $statusColor }}; margin: 0 0 12px 0;">
    {{ if eq .Status "firing" }}[告警] 故障触发{{ else }}[恢复] 故障已恢复{{ end }}
  </h2>

  <table style="border-collapse: collapse; margin-bottom: 16px;">
    <tr>
      <td style="padding: 4px 12px 4px 0; color: #666;">告警名称：</td>
      <td style="padding: 4px 0;"><b>{{ .CommonLabels.alertname }}</b></td>
    </tr>
    <tr>
      <td style="padding: 4px 12px 4px 0; color: #666;">当前状态：</td>
      <td style="padding: 4px 0;"><b style="color: {{ $statusColor }};">{{ .Status | toUpper }}</b></td>
    </tr>
  </table>

  <hr style="border: none; border-top: 1px solid #ddd;"/>

  {{ range .Alerts }}
    {{ $itemColor := "#d9534f" }}
    {{ if eq .Status "resolved" }}{{ $itemColor = "#5cb85c" }}{{ end }}

    <div style="border-left: 4px solid {{ $itemColor }}; padding: 10px 14px; margin: 12px 0; background: #f9f9f9;">
      <p style="margin: 4px 0;"><b>级别：</b>
        <span style="color: {{ $itemColor }};">{{ .Labels.severity }}</span>
      </p>
      <p style="margin: 4px 0;"><b>实例：</b>{{ .Labels.instance }}</p>
      {{ if .Labels.job }}
      <p style="margin: 4px 0;"><b>Job：</b>{{ .Labels.job }}</p>
      {{ end }}
      <p style="margin: 4px 0;"><b>描述：</b>{{ .Annotations.summary }}</p>
      {{ if .Annotations.description }}
      <p style="margin: 4px 0;"><b>详情：</b>{{ .Annotations.description }}</p>
      {{ end }}
      <p style="margin: 4px 0;"><b>开始时间：</b>{{ .StartsAt.Local.Format "2006-01-02 15:04:05" }}</p>
      {{ if eq .Status "resolved" }}
      <p style="margin: 4px 0;"><b>恢复时间：</b>{{ .EndsAt.Local.Format "2006-01-02 15:04:05" }}</p>
      {{ end }}
    </div>
  {{ end }}

  <p style="color: #999; font-size: 12px; margin-top: 20px;">
    本邮件由 Alertmanager 自动发送，请勿直接回复。
  </p>

</div>
{{ end }}
